<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1"/>
  <meta name="generator" content="deepiri-vizult <%= vizult_version %>"/>
  <title>vizult · architecture graph</title>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&family=Outfit:wght@400;500;600;700&display=swap" rel="stylesheet"/>
  <script src="<%= cytoscape_cdn %>"></script>
  <style>
    :root {
      --sidebar-bg: #0f172a;
      --sidebar-border: #1e293b;
      --sidebar-text: #e2e8f0;
      --sidebar-muted: #94a3b8;
      --accent: #38bdf8;
      --accent-dim: rgba(56, 189, 248, 0.15);
      --canvas-bg: #f1f5f9;
      --canvas-grid: rgba(15, 23, 42, 0.06);
      --panel: #1e293b;
      --success: #22c55e;
      --font-ui: "Outfit", system-ui, sans-serif;
      --font-mono: "JetBrains Mono", ui-monospace, monospace;
    }
    * { box-sizing: border-box; }
    html, body { height: 100%; margin: 0; }
    body {
      font-family: var(--font-ui);
      display: flex;
      color: var(--sidebar-text);
      background: var(--sidebar-bg);
    }
    #sidebar {
      width: 300px;
      min-width: 280px;
      border-right: 1px solid var(--sidebar-border);
      display: flex;
      flex-direction: column;
      overflow: hidden;
    }
    .sidebar-scroll {
      flex: 1;
      overflow-y: auto;
      padding: 1.25rem 1.1rem 1.5rem;
    }
    .brand {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: 0.5rem;
      margin-bottom: 0.35rem;
    }
    .brand h1 {
      font-size: 1.35rem;
      font-weight: 700;
      letter-spacing: -0.02em;
      margin: 0;
      color: #fff;
    }
    .brand span {
      font-size: 0.7rem;
      font-weight: 500;
      color: var(--sidebar-muted);
      font-family: var(--font-mono);
    }
    .stats {
      display: flex;
      gap: 0.5rem;
      margin: 0.75rem 0 1rem;
    }
    .stat {
      flex: 1;
      background: var(--panel);
      border-radius: 8px;
      padding: 0.5rem 0.65rem;
      border: 1px solid var(--sidebar-border);
    }
    .stat strong {
      display: block;
      font-size: 1.25rem;
      font-weight: 700;
      color: var(--accent);
      line-height: 1.1;
    }
    .stat small {
      font-size: 0.65rem;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      color: var(--sidebar-muted);
    }
    .hint {
      font-size: 0.78rem;
      line-height: 1.45;
      color: var(--sidebar-muted);
      margin: 0 0 1.1rem;
    }
    .section-label {
      font-size: 0.65rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--sidebar-muted);
      margin: 1rem 0 0.4rem;
    }
    .section-label:first-of-type { margin-top: 0; }
    label.field-label {
      display: block;
      font-size: 0.72rem;
      font-weight: 500;
      color: #cbd5e1;
      margin: 0.55rem 0 0.25rem;
    }
    input[type="search"], select {
      width: 100%;
      padding: 0.45rem 0.55rem;
      font-size: 0.85rem;
      font-family: var(--font-ui);
      border: 1px solid var(--sidebar-border);
      border-radius: 6px;
      background: var(--panel);
      color: var(--sidebar-text);
    }
    input[type="search"]::placeholder { color: #64748b; }
    input[type="search"]:focus, select:focus {
      outline: none;
      border-color: var(--accent);
      box-shadow: 0 0 0 2px var(--accent-dim);
    }
    .btn-row {
      display: flex;
      gap: 0.45rem;
      margin-top: 0.75rem;
    }
    button.btn {
      flex: 1;
      font-family: var(--font-ui);
      font-size: 0.78rem;
      font-weight: 600;
      padding: 0.45rem 0.5rem;
      border-radius: 6px;
      border: 1px solid var(--sidebar-border);
      cursor: pointer;
      background: var(--panel);
      color: var(--sidebar-text);
    }
    button.btn:hover {
      background: #334155;
      border-color: #475569;
    }
    button.btn-primary {
      background: rgba(56, 189, 248, 0.12);
      border-color: rgba(56, 189, 248, 0.35);
      color: var(--accent);
    }
    button.btn-primary:hover {
      background: rgba(56, 189, 248, 0.2);
    }
    .legend {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0.35rem 0.5rem;
      font-size: 0.72rem;
      color: var(--sidebar-muted);
      margin-top: 0.5rem;
    }
    .legend span {
      display: flex;
      align-items: center;
      gap: 0.35rem;
    }
    .swatch {
      width: 10px;
      height: 10px;
      border-radius: 2px;
      border: 1px solid rgba(255,255,255,0.12);
    }
    #detail-wrap {
      border-top: 1px solid var(--sidebar-border);
      background: #020617;
      padding: 0.85rem 1.1rem 1rem;
      max-height: 38vh;
      min-height: 120px;
      display: flex;
      flex-direction: column;
    }
    #detail-wrap h2 {
      font-size: 0.65rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--sidebar-muted);
      margin: 0 0 0.5rem;
    }
    #detail {
      font-family: var(--font-mono);
      font-size: 0.72rem;
      line-height: 1.5;
      color: #cbd5e1;
      white-space: pre-wrap;
      word-break: break-all;
      overflow-y: auto;
      flex: 1;
    }
    #detail.empty {
      color: #64748b;
      font-style: italic;
      font-family: var(--font-ui);
    }
    #cy {
      flex: 1;
      min-width: 0;
      min-height: 400px;
      background-color: var(--canvas-bg);
      background-image:
        linear-gradient(var(--canvas-grid) 1px, transparent 1px),
        linear-gradient(90deg, var(--canvas-grid) 1px, transparent 1px);
      background-size: 24px 24px;
    }
  </style>
</head>
<body>
  <aside id="sidebar">
    <div class="sidebar-scroll">
      <div class="brand">
        <h1>vizult</h1>
        <span>v<%= vizult_version %></span>
      </div>
      <div class="stats">
        <div class="stat"><strong><%= node_count %></strong><small>nodes</small></div>
        <div class="stat"><strong><%= edge_count %></strong><small>edges</small></div>
      </div>
      <p class="hint">Pan and zoom the canvas. Click a node for its edges. Click empty space to clear.</p>

      <div class="section-label">Find</div>
      <label class="field-label" for="search">Search</label>
      <input id="search" type="search" placeholder="id or label…" autocomplete="off"/>

      <div class="section-label">Filters</div>
      <label class="field-label" for="filterType">Node type</label>
      <select id="filterType">
        <option value="">All types</option>
        <option value="repo">repo</option>
        <option value="service">service</option>
        <option value="stream">stream</option>
        <option value="database">database</option>
        <option value="endpoint">endpoint</option>
      </select>
      <label class="field-label" for="filterConfidence">Min edge confidence</label>
      <select id="filterConfidence">
        <option value="">All confidence</option>
        <option value="high">High only</option>
        <option value="medium">High + medium</option>
      </select>
      <label class="field-label" for="filterEdge">Edge type</label>
      <select id="filterEdge">
        <option value="">All edges</option>
        <option value="http_call">http_call</option>
        <option value="http_proxy">http_proxy</option>
        <option value="depends_on">depends_on</option>
        <option value="publishes">publishes</option>
        <option value="consumes">consumes</option>
        <option value="db_access">db_access</option>
        <option value="websocket">websocket</option>
        <option value="imports">imports</option>
        <option value="contains">contains</option>
        <option value="adjacent_clone">adjacent_clone</option>
        <option value="same_org">same_org</option>
        <option value="manifest_ref">manifest_ref</option>
        <option value="scan_overlay">scan_overlay</option>
      </select>

      <div class="btn-row">
        <button type="button" class="btn btn-primary" id="btnFit" title="Fit graph in view">Fit</button>
        <button type="button" class="btn" id="btnLayout" title="Re-run force layout">Layout</button>
      </div>

      <div class="section-label">Node colors</div>
      <div class="legend">
        <span><i class="swatch" style="background:#c7d2fe"></i>default</span>
        <span><i class="swatch" style="background:#bbf7d0"></i>service</span>
        <span><i class="swatch" style="background:#fde68a"></i>repo</span>
        <span><i class="swatch" style="background:#93c5fd"></i>stream</span>
        <span><i class="swatch" style="background:#fecaca"></i>database</span>
      </div>
    </div>
    <div id="detail-wrap">
      <h2>Selection</h2>
      <div id="detail" class="empty">No node selected.</div>
    </div>
  </aside>
  <div id="cy" role="application" aria-label="Graph canvas"></div>

  <script type="application/json" id="vizult-elements"><%= elements_json %></script>
  <script type="application/json" id="vizult-graph"><%= graph_json %></script>
  <script>
(function() {
  var raw = document.getElementById('vizult-elements').textContent;
  var elements = JSON.parse(raw);
  var detailEl = document.getElementById('detail');

  function setDetailEmpty() {
    detailEl.textContent = 'No node selected.';
    detailEl.classList.add('empty');
  }

  function setDetailText(text) {
    detailEl.textContent = text;
    detailEl.classList.remove('empty');
  }

  var cy = cytoscape({
    container: document.getElementById('cy'),
    elements: elements,
    style: [
      { selector: 'node', style: {
        'label': 'data(label)',
        'font-size': '11px',
        'font-family': 'Outfit, system-ui, sans-serif',
        'font-weight': '500',
        'text-wrap': 'wrap',
        'text-max-width': '120px',
        'width': 'label',
        'height': 'label',
        'padding': '10px',
        'background-color': '#c7d2fe',
        'border-width': 1.5,
        'border-color': '#6366f1',
        'color': '#1e1b4b'
      }},
      { selector: 'node[type = "service"]', style: {
        'background-color': '#bbf7d0',
        'border-color': '#16a34a',
        'color': '#14532d'
      }},
      { selector: 'node[type = "repo"]', style: {
        'background-color': '#fde68a',
        'border-color': '#ca8a04',
        'color': '#422006'
      }},
      { selector: 'node[type = "stream"]', style: {
        'background-color': '#93c5fd',
        'border-color': '#2563eb',
        'color': '#1e3a5f'
      }},
      { selector: 'node[type = "database"]', style: {
        'background-color': '#fecaca',
        'border-color': '#dc2626',
        'color': '#450a0a'
      }},
      { selector: 'node:selected', style: {
        'border-width': 3,
        'border-color': '#38bdf8',
        'overlay-opacity': 0
      }},
      { selector: 'edge', style: {
        'width': 2,
        'line-color': '#94a3b8',
        'target-arrow-color': '#94a3b8',
        'target-arrow-shape': 'triangle',
        'curve-style': 'bezier',
        'label': 'data(label)',
        'font-size': '9px',
        'font-family': 'JetBrains Mono, monospace',
        'color': '#475569',
        'text-background-color': '#f1f5f9',
        'text-background-opacity': 0.92,
        'text-background-padding': '2px'
      }},
      { selector: 'edge[?inferred]', style: {
        'line-style': 'dashed',
        'line-color': '#a8a29e',
        'target-arrow-color': '#a8a29e'
      }},
      { selector: 'edge[?scanOverlay]', style: {
        'line-color': '#16a34a',
        'target-arrow-color': '#16a34a',
        'width': 3
      }}
    ],
    layout: { name: 'cose', animate: false, padding: 28, nodeRepulsion: 4500 }
  });

  cy.fit(undefined, 40);

  cy.on('tap', 'node', function(evt) {
    var n = evt.target;
    var id = n.id();
    var out = cy.edges('[source = "' + id + '"]');
    var inn = cy.edges('[target = "' + id + '"]');
    var lines = [id, 'type: ' + (n.data('type') || ''), '—'];
    out.forEach(function(e) {
      var conf = e.data('confidence') || '';
      lines.push('→ ' + e.data('target') + '  [' + e.data('label') + ']  ' + conf);
      var sf = e.data('sourceFile');
      if (sf) lines.push('   ' + sf + (e.data('line') ? ':' + e.data('line') : ''));
    });
    inn.forEach(function(e) {
      lines.push('← ' + e.data('source') + '  [' + e.data('label') + ']  ' + (e.data('confidence') || ''));
    });
    setDetailText(lines.join('\n'));
  });

  cy.on('tap', function(evt) {
    if (evt.target === cy) {
      cy.elements().unselect();
      setDetailEmpty();
    }
  });

  function rankConfidence(c) {
    if (c === 'high') return 3;
    if (c === 'medium') return 2;
    if (c === 'low') return 1;
    return 2;
  }

  function nodeVisible(n, q, nt) {
    var matchQ = !q || (n.id().toLowerCase().indexOf(q) !== -1) ||
      ((n.data('label') || '').toLowerCase().indexOf(q) !== -1);
    var matchT = !nt || n.data('type') === nt;
    return matchQ && matchT;
  }

  function applyFilters() {
    var q = (document.getElementById('search').value || '').toLowerCase();
    var nt = document.getElementById('filterType').value;
    var et = document.getElementById('filterEdge').value;
    var fc = document.getElementById('filterConfidence').value;
    var minRank = fc === 'high' ? 3 : (fc === 'medium' ? 2 : 0);

    cy.nodes().forEach(function(n) {
      var ok = nodeVisible(n, q, nt);
      n.style('display', ok ? 'element' : 'none');
    });

    cy.edges().forEach(function(e) {
      var okType = !et || e.data('label') === et;
      var cr = rankConfidence(e.data('confidence') || 'medium');
      var okConf = minRank === 0 || cr >= minRank;
      var s = e.source();
      var t = e.target();
      var endsOk = s.style('display') !== 'none' && t.style('display') !== 'none';
      e.style('display', (okType && okConf && endsOk) ? 'element' : 'none');
    });
  }

  document.getElementById('filterType').addEventListener('change', applyFilters);
  document.getElementById('filterConfidence').addEventListener('change', applyFilters);
  document.getElementById('filterEdge').addEventListener('change', applyFilters);
  document.getElementById('search').addEventListener('input', applyFilters);

  document.getElementById('btnFit').addEventListener('click', function() {
    cy.fit(undefined, 48);
  });
  document.getElementById('btnLayout').addEventListener('click', function() {
    cy.layout({
      name: 'cose',
      animate: true,
      animationDuration: 380,
      animationEasing: 'ease-out-cubic',
      padding: 28,
      nodeRepulsion: 4500
    }).run();
  });
})();
  </script>
</body>
</html>
